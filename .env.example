# ── Telegram MTProto (GramJS user account) ───────────────────────────────────
# Obtain at https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Run `node gen_session.js` once locally to generate this
TG_SESSION_STRING=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create via @BotFather
BOT_TOKEN=

# Your personal channel username (e.g. @mychannel) or numeric ID (-100...)
TARGET_CHAT_ID=

# ── Gemini API ────────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# Comma-separated list of source channel usernames
SOURCE_CHANNELS=@FastStockNews,@HANAchina,@aetherjapanresearch

# How many hours back to look
LOOKBACK_HOURS=24

# Max messages fetched per channel
MAX_MSGS_PER_CH=30

# Digest header title
DIGEST_TITLE=Korean News Digest

# Gemini model (default: gemini-2.5-flash-preview-04-17)
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Items per Gemini request (default: 50 — Gemini handles large batches well)
GEMINI_BATCH_SIZE=50
