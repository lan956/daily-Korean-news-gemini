# ── Telegram MTProto (Telethon user account) ─────────────────────────────────
# Obtain at https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# Run scripts/gen_session.py once locally to generate this
TG_SESSION_STRING=

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Create via @BotFather
BOT_TOKEN=

# Your personal channel username (e.g. @mychannel) or numeric ID (-100...)
TARGET_CHAT_ID=

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Optional overrides ────────────────────────────────────────────────────────
# Comma-separated list of source channel usernames
SOURCE_CHANNELS=@yonhap_news_kor,@kbs_news,@mbc_news_korea

# How many hours back to look
LOOKBACK_HOURS=24

# Max messages fetched per channel
MAX_MSGS_PER_CH=30

# Digest header title
DIGEST_TITLE=Korean News Digest

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514
